{
  "name": "simple-autolink",
  "version": "1.0.1",
  "description": "Convert plain-text mentions of note titles and aliases into wiki links.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "obsidian",
    "plugin",
    "wikilinks",
    "autolink"
  ],
  "author": "abgmgp",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "obsidian": "^1.5.7",
    "prettier": "^3.2.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
